{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "leek-fund",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": {
        "all": false,
        "request": true,
        "scope": ["http://fundgz.1234567.com.cn/**"]
      },
      "fs": {
        "all": false,
        "scope": ["$APPDATA/leek-fund/*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.leek.fund",
      "icon": [
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/32x32.png"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "基金查询客户端",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}
